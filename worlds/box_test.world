<?xml version="1.0" ?>
<sdf version="1.6">
  <world name="default">
    <!-- A global light source -->
    <include>
      <uri>model://sun</uri>
    </include>

    <!-- A ground plane -->
    <include>
      <uri>model://ground_plane</uri>
    </include>

    <!-- The Simple Box -->
    <include>
      <uri>model://simple_box</uri>
      <pose>0 0 0.5 0 0 0</pose> <!-- Raised 0.5m so it sits on ground -->
    </include>
  </world>
</sdf>
